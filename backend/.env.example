# ==============================================================================
# Intelli-Credit Backend Environment Variables Configuration Template
# Copy this file to '.env' in this directory (or the project root) and adjust values.
# ==============================================================================

# FastAPI Settings
# ------------------------------------------------------------------------------
# Set to True/False for debugging purposes
DEBUG=True

# Security Settings
# ------------------------------------------------------------------------------
# Secret key used for signing JWT tokens. Change this to a random secure string in production.
JWT_SECRET_KEY=supersecretkey
# Token expiration time in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database Settings
# ------------------------------------------------------------------------------
# Database connection URL. Defaults to a local SQLite database file.
# To use Supabase (PostgreSQL), configure your PostgreSQL connection URL:
# Example Supabase: postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres
DATABASE_URL=sqlite:///./intelli_credit.db

# LLM (Groq API) Settings
# ------------------------------------------------------------------------------
# API Key for Groq (required). Generate one at https://console.groq.com/
GROQ_API_KEY=
# The Groq model to use (default: llama-3.3-70b-versatile or llama-3.1-8b-instant)
GROQ_MODEL=llama-3.3-70b-versatile

# External APIs Settings
# ------------------------------------------------------------------------------
# NewsAPI key for retrieving news sentiment data (optional). Leave empty to use fallback mock news data.
NEWS_API_KEY=
